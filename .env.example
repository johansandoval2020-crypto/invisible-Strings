# ---------------------------------------------------------------------------
# Invisible String — variables de entorno
# Copia este archivo a .env.local y completa los valores reales.
# Nunca commitear .env.local (ya está en .gitignore).
# ---------------------------------------------------------------------------

# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Base de datos — Project Settings > Database (usar el pooler para DATABASE_URL
# y la conexión directa para DIRECT_URL, que Prisma usa en migraciones)
DATABASE_URL=
DIRECT_URL=

# Spotify — https://developer.spotify.com/dashboard (fase 4, opcional por ahora)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Email transaccional (Resend) — fase 3, notificaciones de cartas/aniversarios
RESEND_API_KEY=
RESEND_FROM_EMAIL="Invisible String <hola@tu-dominio.com>"

# Observabilidad — fase 6
NEXT_PUBLIC_SENTRY_DSN=

# URL base de la app (usada en emails, invitaciones, metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000
